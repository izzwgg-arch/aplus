DATABASE_URL="postgresql://aba_user:change_me@127.0.0.1:5432/aba_db?schema=public"
JWT_SECRET="replace-with-long-random-value"
JWT_EXPIRES_IN="1d"
RESET_TOKEN_EXPIRES_MIN="30"
ENCRYPTION_KEY="32_characters_minimum_key_here__"

EMAIL_HOST="smtp.gmail.com"
EMAIL_PORT="587"
EMAIL_USER="clinic@example.com"
EMAIL_PASS="replace-me"
EMAIL_FROM="A+ Center <clinic@example.com>"

# Live site URL (used for VoIP.ms webhooks when API_BASE_URL is localhost)
APP_BASE_URL="https://your-domain.example"
API_BASE_URL="https://your-domain.example"
# Optional override for webhook links only:
# PUBLIC_WEBHOOK_BASE_URL="https://your-domain.example"
PORT="4000"
UPLOAD_DIR="./uploads"
GLOBAL_HOURLY_RATE="130"
GLOBAL_CANCELLATION_FEE_ENABLED="false"

QUICKBOOKS_CLIENT_ID=""
QUICKBOOKS_CLIENT_SECRET=""
# Redirect URI must match what is registered in the Intuit Developer Portal exactly:
QUICKBOOKS_REDIRECT_URI="https://your-domain.example/api/integrations/quickbooks/callback"
# Set to PRODUCTION once you go live (default: SANDBOX)
QUICKBOOKS_ENVIRONMENT="SANDBOX"

# ── Sola Payments (replaces Payment Hub) ────────────────────────────────────
# Transaction API key — used for all server-side charges
SOLA_XKEY=""
# iFields tokenization key — returned to the browser for card-entry iFrames
SOLA_IFIELDS_KEY=""
# CloudIM key — may equal SOLA_XKEY unless you have a separate CloudIM account
SOLA_CLOUDIM_KEY=""
# Default CloudIM terminal device ID (set per-device in Settings if needed)
SOLA_CLOUDIM_DEVICE_ID=""
# Webhook HMAC secret — configure this in the Sola portal under Webhooks
SOLA_WEBHOOK_SECRET=""
# Webhook URL to register in Sola portal:
#   https://your-domain.example/api/payments/webhook/sola

# ── Legacy Payment Hub (kept for historical transaction records) ─────────────
PAYMENT_HUB_BASE_URL=""
PAYMENT_HUB_WEBHOOK_SECRET=""
PAYMENT_HUB_PUBLIC_KEY=""

GOOGLE_WORKSPACE_CLIENT_ID=""
GOOGLE_WORKSPACE_CLIENT_SECRET=""

# VoIP.ms SMS — optional fallback if not set in Settings → Integrations → VoIP.ms (encrypted in DB)
# DID for sending is in Settings → Reminders
VOIPMS_API_USER=""
VOIPMS_API_PASSWORD=""
VOIPMS_WEBHOOK_SECRET=""
